<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StayLio Admin Dashboard</title>
    <!-- Use the same fonts and standard libraries as main app -->
    <link rel="icon" href="/images/logo3.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.4/jquery.min.js"></script>
</head>
<body>
    <div class="admin-container">
        <!-- Sidebar -->
        <aside class="admin-sidebar" id="sidebar">
            <div class="sidebar-header">
                <a href="/listings" class="admin-brand">
                    <img src="/images/logo3.png" alt="Logo">
                    <span>StayLio Admin</span>
                </a>
            </div>
            <nav class="sidebar-nav">
                <a href="/admin/dashboard" class="nav-link <%= active === 'dashboard' ? 'active' : '' %>">
                    <i class="fas fa-th-large"></i> <span>Overview</span>
                </a>
                <a href="/admin/users" class="nav-link <%= active === 'users' ? 'active' : '' %>">
                    <i class="fas fa-users"></i> <span>Users</span>
                </a>
                <a href="/admin/listings" class="nav-link <%= active === 'listings' ? 'active' : '' %>">
                    <i class="fas fa-home"></i> <span>Listings</span>
                </a>
                <a href="/admin/bookings" class="nav-link <%= active === 'bookings' ? 'active' : '' %>">
                    <i class="fas fa-calendar-check"></i> <span>Bookings</span>
                </a>
                <a href="/admin/reviews" class="nav-link <%= active === 'reviews' ? 'active' : '' %>">
                    <i class="fas fa-star"></i> <span>Reviews</span>
                </a>
                <hr>
                <a href="/listings" class="nav-link">
                    <i class="fas fa-arrow-left"></i> <span>Back to Site</span>
                </a>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="admin-main">
            <!-- Topbar -->
            <header class="admin-topbar">
                <button id="sidebar-toggle" class="btn btn-link">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="topbar-right">
                    <div class="user-info">
                        <span>Welcome, <%= currUser.username %></span>
                        <a href="/logout" class="btn btn-sm btn-outline-danger ms-3">Logout</a>
                    </div>
                </div>
            </header>

            <!-- Page Content -->
            <div class="admin-content">
                <%- include("../includes/flash.ejs") %>
                <%- body %>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('sidebar-toggle').addEventListener('click', function() {
            const sidebar = document.getElementById('sidebar');
            if (window.innerWidth < 992) {
                sidebar.classList.toggle('active');
            } else {
                sidebar.classList.toggle('collapsed');
            }
        });
    </script>
</body>
</html>
