<% layout("/layouts/admin") %>


<div class="container-fluid">
    <div class="row align-items-center mb-4">
        <div class="col">
            <h1 class="h3 mb-0 text-gray-800">Dashboard Overview</h1>
        </div>
    </div>

    <!-- Stat Cards -->
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="stat-card border-left-primary">
                <div class="stat-icon bg-primary shadow">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-details">
                    <h3>Total Users</h3>
                    <p><%= stats.totalUsers %></p>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="stat-card border-left-success">
                <div class="stat-icon bg-success shadow">
                    <i class="fas fa-home"></i>
                </div>
                <div class="stat-details">
                    <h3>Total Listings</h3>
                    <p><%= stats.totalListings %></p>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="stat-card border-left-info">
                <div class="stat-icon bg-info shadow">
                    <i class="fas fa-calendar-alt"></i>
                </div>
                <div class="stat-details">
                    <h3>Total Bookings</h3>
                    <p><%= stats.totalBookings %></p>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="stat-card border-left-warning">
                <div class="stat-icon bg-warning shadow">
                    <i class="fas fa-indian-rupee-sign"></i>
                </div>
                <div class="stat-details">
                    <h3>Total Revenue</h3>
                    <p>₹<%= stats.totalRevenue.toLocaleString() %></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts -->
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="admin-chart-container">
                <h2 class="h5">Monthly Bookings & Revenue Trend</h2>
                <canvas id="bookingsChart" height="300"></canvas>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="admin-chart-container">
                <h2 class="h5">Management Quick Links</h2>
                <div class="list-group list-group-flush mt-3">
                    <a href="/admin/users" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        Manage Users <i class="fas fa-chevron-right text-muted small"></i>
                    </a>
                    <a href="/admin/listings" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        Approve Listings <i class="fas fa-chevron-right text-muted small"></i>
                    </a>
                    <a href="/admin/bookings" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        Manage Bookings <i class="fas fa-chevron-right text-muted small"></i>
                    </a>
                    <a href="/admin/reviews" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        Manage Reviews <i class="fas fa-chevron-right text-muted small"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const chartData = <%- monthlyData %>;
    const ctx = document.getElementById('bookingsChart').getContext('2d');
    
    // Process data for chart
    const labels = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    const bookingsData = new Array(12).fill(0);
    const revenueData = new Array(12).fill(0);
    
    chartData.forEach(item => {
        bookingsData[item._id - 1] = item.bookings;
        revenueData[item._id - 1] = item.revenue;
    });

    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [{
                label: 'Bookings',
                data: bookingsData,
                backgroundColor: 'rgba(254, 66, 77, 0.8)',
                order: 2
            }, {
                label: 'Revenue (x100)',
                data: revenueData.map(r => r/100),
                type: 'line',
                borderColor: '#1e293b',
                fill: false,
                order: 1
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'top',
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: {
                        display: true,
                        color: 'rgba(0,0,0,0.05)'
                    }
                },
                x: {
                    grid: {
                        display: false
                    }
                }
            }
        }
    });
</script>
