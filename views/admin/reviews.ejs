<% layout("/layouts/admin") %>
<% const active = 'reviews' %>

<div class="row align-items-center mb-4">
    <div class="col">
        <h1 class="h3 mb-0 text-gray-800">Reviews Management</h1>
        <p class="text-muted small">Moderate and filter all property reviews for inappropriate content.</p>
    </div>
</div>

<div class="admin-table-container">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th scope="col">Author</th>
                    <th scope="col">Rating</th>
                    <th scope="col">Comment</th>
                    <th scope="col">Created At</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% for(let review of reviews) { %>
                    <tr>
                        <td class="fw-bold"><%= review.author ? review.author.username : 'Deleted User' %></td>
                        <td>
                            <div class="text-warning">
                               <% for(let i=0; i<review.rating; i++) { %>
                                    <i class="fas fa-star"></i>
                               <% } %>
                               <% for(let i=review.rating; i<5; i++) { %>
                                    <i class="far fa-star"></i>
                               <% } %>
                            </div>
                        </td>
                        <td>
                            <div class="text-muted mb-0 small text-truncate" style="max-width: 300px;">
                                <%= review.comment %>
                            </div>
                        </td>
                        <td><%= review.createdAt.toDateString() %></td>
                        <td>
                            <div class="d-flex gap-2">
                                <form action="/admin/reviews/<%= review._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this review?')">
                                    <button class="btn btn-sm btn-outline-danger shadow-sm"><i class="fas fa-trash-alt"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
